{
  "name": "@pagopa/io-app-design-system",
  "version": "8.1.0",
  "description": "The library defining the core components of the design system of @pagopa/io-app",
  "main": "lib/commonjs/index",
  "module": "lib/module/index",
  "types": "lib/typescript/src/index.d.ts",
  "react-native": "src/index",
  "source": "src/index",
  "files": [
    "src",
    "lib",
    "android",
    "ios",
    "cpp",
    "*.podspec",
    "!lib/typescript/example",
    "!ios/build",
    "!android/build",
    "!android/gradle",
    "!android/gradlew",
    "!android/gradlew.bat",
    "!android/local.properties",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "!**/.*"
  ],
  "scripts": {
    "test": "jest --config='./jest.config.js'",
    "tsc-noemit": "tsc --noEmit",
    "lint": "eslint \"**/*.{js,ts,tsx}\"",
    "prettify": "prettier --write \"src/**/*.{ts,tsx}\"",
    "prettier:check": "prettier --check \"src/**/*.{ts,tsx}\"",
    "prepack": "bob build",
    "release": "release-it",
    "generate:icons": "node scripts/generateNewIcons.js",
    "generate:pictograms": "node scripts/generateNewPictograms.js",
    "generate": "pnpm generate:icons && pnpm generate:pictograms"
  },
  "keywords": [
    "react-native",
    "ios",
    "android"
  ],
  "repository": "https://github.com/pagopa/io-app.git",
  "author": "PagoPa (https://github.com/pagopa)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/pagopa/io-app/issues"
  },
  "homepage": "https://github.com/pagopa/io-app/tree/master/libs/esign-system#readme",
  "devDependencies": {
    "@commitlint/config-conventional": "^17.0.2",
    "@release-it/conventional-changelog": "^5.0.0",
    "@stylistic/eslint-plugin": "^2.12.1",
    "@svgr/core": "^8.1.0",
    "@svgr/plugin-jsx": "^8.1.0",
    "@svgr/plugin-svgo": "^8.1.0",
    "@testing-library/react-native": "^13.2.0",
    "@types/jest": "catalog:",
    "@types/markdown-it": "^14.1.2",
    "@types/react": "catalog:",
    "auto-changelog": "^2.4.0",
    "babel-jest": "^29.7.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "commitlint": "^17.0.2",
    "del-cli": "^5.0.0",
    "eslint": "catalog:",
    "eslint-config-prettier": "^8.5.0",
    "eslint-plugin-functional": "^9.0.5",
    "eslint-plugin-import": "^2.27.5",
    "eslint-plugin-jest": "^29.15.5",
    "eslint-plugin-prettier": "^4.0.0",
    "eslint-plugin-react-native-a11y": "^3.3.0",
    "fs-extra": "^11.1.1",
    "jest": "catalog:",
    "react": "catalog:",
    "react-native": "catalog:",
    "react-native-builder-bob": "^0.38.0",
    "react-test-renderer": "catalog:",
    "release-it": "^15.0.0",
    "svgo": "^3.0.2",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-native": "*",
    "react-native-easing-gradient": "*",
    "react-native-gesture-handler": "*",
    "react-native-haptic-feedback": "*",
    "react-native-linear-gradient": "*",
    "react-native-reanimated": ">=4.0.0",
    "react-native-safe-area-context": "*",
    "react-native-svg": "*",
    "react-native-worklets": "*"
  },
  "engines": {
    "node": ">= 20"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "release-it": {
    "git": {
      "commitMessage": "chore: release ${version}",
      "tagName": "Design System: v${version}",
      "changelog": "pnpm auto-changelog --stdout --commit-limit false -u --template https://raw.githubusercontent.com/release-it/release-it/master/templates/changelog-compact.hbs"
    },
    "hooks": {
      "after:bump": "pnpm auto-changelog -p && git add ."
    },
    "npm": {
      "publish": false
    },
    "github": {
      "release": true
    },
    "plugins": {}
  },
  "eslintIgnore": [
    "node_modules/",
    "lib/",
    "example/webpack.config.js",
    "example/metro.config.js",
    "babel.config.js",
    "scripts/",
    ".eslintrc.js"
  ],
  "prettier": {
    "trailingComma": "none",
    "arrowParens": "avoid",
    "parser": "typescript"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
      "module",
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  },
  "dependencies": {
    "markdown-it": "^14.1.0",
    "react-native-easing-gradient": "catalog:",
    "react-native-gesture-handler": "catalog:",
    "react-native-haptic-feedback": "catalog:",
    "react-native-linear-gradient": "catalog:",
    "react-native-reanimated": "catalog:",
    "react-native-safe-area-context": "catalog:",
    "react-native-svg": "catalog:",
    "react-native-worklets": "catalog:"
  }
}
