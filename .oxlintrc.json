{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "react", "jest"],
  "categories": {
    "correctness": "off",
    "suspicious": "off",
    "pedantic": "off",
    "style": "off",
    "restriction": "off",
    "nursery": "off"
  },
  "options": {
    "typeAware": true
  },
  "env": {
    "builtin": true
  },
  "ignorePatterns": [
    "**/*.js",
    "**/*.cjs",
    "**/*.mjs",
    "locales/locales.ts",
    "ts/utils/__tests__/xss.test.ts",
    "definitions/*",
    "**/*.typegen.ts"
  ],
  "overrides": [
    {
      "files": ["**/*.ts", "**/*.tsx"],
      "jsPlugins": [
        "eslint-plugin-eslint-comments",
        "eslint-plugin-react-native",
        "eslint-plugin-react-native-a11y",
        "eslint-plugin-functional",
        "eslint-plugin-i18next",
        "@react-native/eslint-plugin",
        {
          "name": "react-js",
          "specifier": "eslint-plugin-react"
        },
        {
          "name": "compat",
          "specifier": "./scripts/eslint/oxlint-compat-plugin.js"
        }
      ],
      "env": {
        "es2026": true
      },
      "globals": {
        "__DEV__": "writable",
        "__dirname": "readonly",
        "__fbBatchedBridgeConfig": "readonly",
        "AbortController": "readonly",
        "Blob": "writable",
        "alert": "readonly",
        "cancelAnimationFrame": "readonly",
        "cancelIdleCallback": "readonly",
        "clearImmediate": "writable",
        "clearInterval": "readonly",
        "clearTimeout": "readonly",
        "console": "readonly",
        "document": "readonly",
        "ErrorUtils": "readonly",
        "Event": "readonly",
        "EventTarget": "readonly",
        "exports": "readonly",
        "fetch": "readonly",
        "File": "writable",
        "FileReader": "readonly",
        "FormData": "readonly",
        "global": "readonly",
        "Headers": "readonly",
        "Map": "writable",
        "module": "readonly",
        "navigator": "readonly",
        "process": "readonly",
        "Promise": "writable",
        "requestAnimationFrame": "writable",
        "requestIdleCallback": "writable",
        "require": "readonly",
        "Set": "writable",
        "setImmediate": "writable",
        "setInterval": "readonly",
        "setTimeout": "readonly",
        "queueMicrotask": "writable",
        "URL": "readonly",
        "URLSearchParams": "readonly",
        "WebSocket": "writable",
        "window": "readonly",
        "XMLHttpRequest": "readonly"
      },
      "rules": {
        // ─── eslint core (recommended) ────────────────────────────────────
        "for-direction": "error",
        "no-async-promise-executor": "error",
        "no-case-declarations": "off",
        "no-compare-neg-zero": "error",
        "no-cond-assign": "warn",
        "no-const-assign": "error",
        "no-constant-binary-expression": "error",
        "no-control-regex": "warn",
        "no-debugger": "warn",
        "no-delete-var": "warn",
        "no-dupe-class-members": "error",
        "no-dupe-else-if": "error",
        "no-dupe-keys": "error",
        "no-duplicate-case": "error",
        "no-empty-character-class": "warn",
        "no-empty-pattern": "error",
        "no-empty-static-block": "error",
        "no-ex-assign": "warn",
        "no-extra-boolean-cast": "warn",
        "no-fallthrough": "warn",
        "no-func-assign": "warn",
        "no-global-assign": "error",
        "no-invalid-regexp": "warn",
        "no-irregular-whitespace": "error",
        "no-loss-of-precision": "error",
        "no-misleading-character-class": "error",
        "no-nonoctal-decimal-escape": "error",
        "no-obj-calls": "warn",
        "no-prototype-builtins": "error",
        "no-regex-spaces": "warn",
        "no-self-assign": "error",
        "no-shadow-restricted-names": "warn",
        "no-sparse-arrays": "warn",
        "no-unassigned-vars": "error",
        "no-unreachable": "error",
        "no-unsafe-finally": "error",
        "no-unsafe-optional-chaining": "error",
        "no-unused-labels": "error",
        "no-unused-private-class-members": "error",
        "no-unused-vars": "off",
        "no-useless-backreference": "error",
        "no-useless-catch": "error",
        "no-useless-escape": "warn",
        "no-with": "warn",
        "preserve-caught-error": "error",
        "require-yield": "error",
        "use-isnan": "warn",
        "valid-typeof": "warn",

        // ─── eslint core (custom) ─────────────────────────────────────────
        "no-var": "error",
        "prefer-const": "error",
        "prefer-rest-params": "error",
        "prefer-spread": "error",
        "curly": "error",
        "no-console": "error",
        "no-inner-declarations": "off",
        "complexity": "error",
        "eqeqeq": ["error", "smart"],
        "guard-for-in": "error",
        "no-caller": "error",
        "no-eval": "error",
        "no-new-wrappers": "error",
        "no-new-func": "error",
        "no-param-reassign": "error",
        "no-throw-literal": "error",
        "no-void": "off",
        "no-bitwise": "error",
        "no-duplicate-imports": "error",
        "no-unused-expressions": ["error"],
        "max-classes-per-file": ["error", 1],
        "arrow-body-style": "error",
        "radix": "error",
        "no-alert": "warn",
        "no-div-regex": "warn",
        "no-extend-native": "warn",
        "no-extra-bind": "warn",
        "no-labels": "warn",
        "no-iterator": "warn",
        "no-lone-blocks": "warn",
        "no-new": "warn",
        "no-proto": "warn",
        "no-return-assign": "warn",
        "no-script-url": "warn",
        "no-self-compare": "warn",
        "no-sequences": "warn",
        "no-label-var": "warn",
        "no-shadow": "warn",
        "no-array-constructor": "warn",
        "yoda": "warn",
        "no-restricted-imports": [
          "error",
          {
            "paths": [
              {
                "name": "i18n-js",
                "message": "Importing I18n from \"i18n-js\" is not allowed. Import it from \"ts/i18n.ts\" instead."
              },
              {
                "name": "@pagopa/ts-commons",
                "importNames": ["pot"],
                "message": "Importing { pot } from \"@pagopa/ts-commons\" is not allowed. Use 'import * as pot from \"@pagopa/ts-commons/lib/pot\"' instead."
              },
              {
                "name": "redux-saga/effects",
                "message": "Importing from \"redux-saga/effects\" is not allowed. Use \"typed-redux-saga/macro\" instead for type-safe saga effects."
              }
            ]
          }
        ],

        // ─── eslint core (not natively implemented → compat jsPlugin) ─────
        "compat/one-var": ["error", "never"],
        "compat/object-shorthand": "error",
        "compat/no-underscore-dangle": "error",

        // ─── typescript ───────────────────────────────────────────────────
        "typescript/ban-ts-comment": "error",
        "typescript/no-duplicate-enum-values": "error",
        "typescript/no-empty-object-type": "error",
        "typescript/no-explicit-any": "off",
        "typescript/no-extra-non-null-assertion": "error",
        "typescript/no-misused-new": "error",
        "typescript/no-namespace": "error",
        "typescript/no-non-null-asserted-optional-chain": "error",
        "typescript/no-require-imports": [
          "error",
          {
            "allow": [
              "\\.png$",
              "\\.jpg$",
              "\\.jpeg$",
              "\\.gif$",
              "\\.svg",
              "\\.webp$"
            ]
          }
        ],
        "typescript/no-this-alias": "error",
        "typescript/no-unnecessary-type-constraint": "error",
        "typescript/no-unsafe-declaration-merging": "error",
        "typescript/no-unsafe-function-type": "error",
        "typescript/no-wrapper-object-types": "error",
        "typescript/prefer-as-const": "error",
        "typescript/prefer-namespace-keyword": "error",
        "typescript/triple-slash-reference": "error",
        "typescript/explicit-module-boundary-types": "off",
        "typescript/no-inferrable-types": "off",
        "typescript/array-type": ["error", { "default": "generic" }],
        "typescript/consistent-type-assertions": "error",
        "typescript/prefer-function-type": "error",
        "typescript/unified-signatures": "error",
        // type-aware
        "typescript/await-thenable": "error",
        "typescript/dot-notation": "error",
        "typescript/no-floating-promises": "error",
        "typescript/restrict-plus-operands": "error",

        // ─── react (native plugin) ───────────────────────────────────────
        "react/display-name": "off",
        "react/jsx-no-comment-textnodes": "error",
        "react/jsx-no-duplicate-props": "error",
        "react/jsx-no-undef": "error",
        "react/no-did-mount-set-state": "warn",
        "react/no-string-refs": "error",
        "react/no-unknown-property": "off",
        "react/react-in-jsx-scope": "off",
        "react/self-closing-comp": "warn",
        "react/jsx-key": "error",
        "react/no-direct-mutation-state": "off",
        "react/require-render-return": "off",
        "react/rules-of-hooks": "error",
        "react/exhaustive-deps": "error",

        // ─── react (jsPlugin — rules not natively implemented) ───────────
        "react-js/jsx-no-bind": ["error", { "allowArrowFunctions": true }],

        // ─── react-native (jsPlugin) ─────────────────────────────────────
        "react-native/no-unused-styles": "error",
        "react-native/split-platform-components": "off",
        "react-native/no-inline-styles": "off",
        "react-native/no-color-literals": "error",
        "react-native/no-raw-text": "off",
        "react-native/no-single-element-style-arrays": "warn",

        // ─── react-native-a11y (jsPlugin) ────────────────────────────────
        "react-native-a11y/has-accessibility-hint": "off",
        "react-native-a11y/has-accessibility-props": "error",
        "react-native-a11y/has-valid-accessibility-actions": "error",
        "react-native-a11y/has-valid-accessibility-component-type": "error",
        "react-native-a11y/has-valid-accessibility-descriptors": "error",
        "react-native-a11y/has-valid-accessibility-role": "error",
        "react-native-a11y/has-valid-accessibility-state": "error",
        "react-native-a11y/has-valid-accessibility-states": "error",
        "react-native-a11y/has-valid-accessibility-traits": "error",
        "react-native-a11y/has-valid-accessibility-value": "error",
        "react-native-a11y/no-nested-touchables": "error",
        "react-native-a11y/has-valid-accessibility-ignores-invert-colors": "error",
        "react-native-a11y/has-valid-accessibility-live-region": "error",
        "react-native-a11y/has-valid-important-for-accessibility": "error",

        // ─── @react-native (jsPlugin) ────────────────────────────────────
        "@react-native/no-deep-imports": "warn",

        // ─── jest (native plugin) ────────────────────────────────────────
        "jest/no-disabled-tests": "warn",
        "jest/no-focused-tests": "warn",
        "jest/no-identical-title": "warn",
        "jest/valid-expect": "warn",

        // ─── eslint-comments (jsPlugin + native) ─────────────────────────
        "eslint-comments/no-aggregating-enable": "warn",
        "unicorn/no-abusive-eslint-disable": "warn",
        "eslint-comments/no-unused-disable": "warn",
        "eslint-comments/no-unused-enable": "warn",

        // ─── functional (jsPlugin) ───────────────────────────────────────
        "functional/no-let": "error",
        "functional/immutable-data": [
          "error",
          {
            "ignoreAccessorPattern": [
              "navigation.**",
              "navigate.**",
              "StackActions.**"
            ]
          }
        ],

        // ─── i18next (jsPlugin) ──────────────────────────────────────────
        "i18next/no-literal-string": [
          "error",
          {
            "mode": "jsx-only",
            "jsx-attributes": {
              "include": [
                "accessibilityLabel",
                "accessibilityHint",
                "placeholder",
                "title",
                "alt"
              ],
              "exclude": []
            },
            "jsx-components": {
              "include": [],
              "exclude": ["Trans"]
            },
            "words": {
              "exclude": [
                "\\s+",
                "[0-9!-/:-@\\[-`{-~]+",
                "[•·]+",
                "."
              ]
            },
            "object-properties": {
              "include": [],
              "exclude": ["testID"]
            }
          }
        ],

        // ─── typed-redux-saga custom rule (compat jsPlugin) ──────────────
        "compat/delegate-effects": "error"
      }
    },
    {
      "files": ["**/*.test.ts", "**/*.test.tsx"],
      "jsPlugins": ["eslint-plugin-i18next"],
      "rules": {
        "i18next/no-literal-string": "off",
        "no-restricted-imports": "off",
        "no-shadow": "off",
        "typescript/no-non-null-assertion": "off",
        "typescript/no-require-imports": "off"
      }
    },
    {
      "files": [
        "**/design-system/**/*.ts",
        "**/design-system/**/*.tsx",
        "**/playgrounds/**/*.ts",
        "**/playgrounds/**/*.tsx",
        "**/devMode/**/*.ts",
        "**/devMode/**/*.tsx",
        "**/debug/**/*.ts",
        "**/debug/**/*.tsx",
        "**/__mocks__/**/*.ts",
        "**/__mocks__/**/*.tsx"
      ],
      "jsPlugins": ["eslint-plugin-i18next"],
      "rules": {
        "i18next/no-literal-string": "off"
      }
    }
  ]
}
