{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "type": "command",
        "bash": "bash .github/hooks/scripts/session-start.sh",
        "timeoutSec": 1800
      }
    ],
    "sessionEnd": [
      {
        "type": "command",
        "bash": "node .github/hooks/scripts/session-end.mjs",
        "powershell": "node .github/hooks/scripts/session-end.mjs",
        "timeoutSec": 900
      }
    ]
  }
}
